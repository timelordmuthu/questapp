# =============================================================================
# Quest App — Backend Environment Variables
# Copy this to .env and fill in your values for local development.
# =============================================================================

# Database (local: use docker-compose; production: Render Internal URL)
DATABASE_URL=postgresql+asyncpg://questapp:localpass@localhost:5432/questapp
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (local: docker-compose; production: Render Internal URL)
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=changeme-generate-with-secrets.token_hex-32
SESSION_TTL_DAYS=30

# Email — Resend (password reset)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@questapp.io
PASSWORD_RESET_EXPIRY_MINUTES=30

# Cloudinary (avatar uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=quest-app/avatars

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
